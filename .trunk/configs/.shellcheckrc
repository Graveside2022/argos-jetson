enable=all
source-path=SCRIPTDIR
disable=SC2154

# SC2250 disabled: the trunk/shellcheck SC2250 autofix corrupts quoting
# inside command substitution with embedded $vars (e.g.
# `$(echo "$FOO" | wc -l)` → `$(echo${"$FO}O" | wc -l)`). Rule is pure
# style (prefer ${var} over $var). Keeping vars readable, skipping
# autofix risk across Argos's shell codebase (59+ scripts).
disable=SC2250

# SC2312 disabled during trunk adoption: "consider invoking this command
# separately to avoid masking its return value" — fires on nearly every
# `$(cmd | filter)` pipeline in Argos's install/deploy scripts (141+
# occurrences). Rule catches real bugs in isolated cases but hold-the-line
# flags ALL on any touched file, blocking PRs mechanically. Reassess after
# baseline is on main; can re-enable with narrow file-level annotations.
disable=SC2312

# If you're having issues with shellcheck following source, disable the errors via:
# disable=SC1090
# disable=SC1091
