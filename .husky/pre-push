#!/usr/bin/env sh
# Pre-push chain (heavy-gate tier — runs once per `git push`):
#   1. Block direct pushes to protected branches (main, master).
#   2. Full-repo typecheck (svelte-check via mem-guard wrapper).
#   3. Full-repo ESLint scan (cached).
#   4. test:unit:related:upstream — scoped to files changed vs upstream.
#
# All checks run before anything leaves the local machine. CI is the third
# layer (.github/workflows/ci.yml + lint.yml).
#
# All three checks share scripts/ops/mem-guard.sh's flock so two concurrent
# pre-push runs (e.g. double-click `git push` in a UI) can't race on RAM/CPU.
#
# Bypass protected-branch guard: ALLOW_MAIN_PUSH=1 git push ...
# Bypass full-repo lint:         SKIP_FULL_LINT=1 git push ...
# Bypass related-tests stage:    SKIP_TESTS=1 git push ...        (use when running inside an agent runtime that SIGTERMs subprocesses at ~3 min; CI runs full suite)
# Skip everything:               git push --no-verify ...

set -e

# 1) Protected-branch push guard (must consume git's ref-list from stdin first)
if [ "${ALLOW_MAIN_PUSH:-0}" = "1" ]; then
	echo "[pre-push] ALLOW_MAIN_PUSH=1 — bypass engaged, pushing to protected branch"
else
	PROTECTED='main master'
	while read -r local_ref local_sha remote_ref remote_sha; do
		[ -z "$remote_ref" ] && continue
		case "$local_sha" in
			0000000*) continue ;;
		esac
		remote_branch=${remote_ref#refs/heads/}
		for pb in $PROTECTED; do
			if [ "$remote_branch" = "$pb" ]; then
				echo "[pre-push] ❌ direct push to '$pb' is blocked" >&2
				echo "[pre-push]    Open a PR from a feature branch instead" >&2
				echo "[pre-push]    Emergency bypass: ALLOW_MAIN_PUSH=1 git push ..." >&2
				exit 1
			fi
		done
	done
fi

# 2) Typecheck (svelte-check via mem-guard wrapper in package.json)
# npm run typecheck is already wrapped in mem-guard via its package.json
# script definition — wrapping it again here would cause a nested-lock failure.
echo "[pre-push] typecheck (svelte-check)..."
npm run typecheck

# 3) Full-repo ESLint scan (cached, blocking on any error)
if [ "${SKIP_FULL_LINT:-0}" = "1" ]; then
	echo "[pre-push] SKIP_FULL_LINT=1 — skipping full-repo eslint scan"
else
	echo "[pre-push] full-repo eslint scan (cached, cognitive complexity ≤5)..."
	if ! npx eslint . --config config/eslint.config.js --cache --cache-location .eslintcache --cache-strategy content; then
		echo "[pre-push] ❌ eslint errors present — fix or bypass with SKIP_FULL_LINT=1 git push ..." >&2
		exit 1
	fi
fi

# 4) test:unit:related:upstream — scoped to the diff being pushed
# Full 523-test suite runs in CI only — pre-push scopes to files changed vs the
# upstream tracking branch. Catches breakage in the actual diff without paying
# ~120 s on pushes that touch a handful of files. CI is the safety net.
#
# Bypass: SKIP_TESTS=1 git push ...
#   Use when running pushes inside an agent runtime that imposes a ~3-min
#   subprocess ceiling (e.g. Claude Code's bg-task wrapper) and tests would
#   otherwise be SIGTERM'd mid-run. CI is authoritative; this stage is local
#   belt-and-suspenders.
if [ "${SKIP_TESTS:-0}" = "1" ]; then
	echo "[pre-push] SKIP_TESTS=1 — skipping vitest related-tests stage (CI will run the full suite)"
else
	echo "[pre-push] test:unit:related:upstream (scoped to the diff being pushed)..."
	npm run test:unit:related:upstream
fi

echo "[pre-push] ✓ all checks passed"
