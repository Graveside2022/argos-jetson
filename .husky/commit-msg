#!/usr/bin/env sh
# Conventional Commits enforcement.
# Single-source from commitlint.config.mjs via `npx commitlint --edit`.
# Replaced the prior hand-rolled regex (which duplicated the config) on
# 2026-04-29 per docs/ci-cd-pipeline-spec.md §3.3.
#
# Bypass: SKIP_COMMIT_MSG=1 git commit ...  OR  git commit --no-verify ...

set -e

if [ "${SKIP_COMMIT_MSG:-0}" = "1" ]; then
	echo "[commit-msg] SKIP_COMMIT_MSG=1 — skipping"
	exit 0
fi

MSG_FILE=$1
[ -f "$MSG_FILE" ] || exit 0

MSG_HEAD=$(grep -vE '^(#|$)' "$MSG_FILE" | head -1)

# Skip generated commit messages git produces during merge / revert / fixup
case "$MSG_HEAD" in
	"Merge "*|"Revert "*|"fixup!"*|"squash!"*|"amend!"*|"WIP"*|"Initial commit"*)
		exit 0
		;;
esac

# Delegate to commitlint — single source of truth from commitlint.config.mjs.
# --no-install ensures we use the local install (no surprise network fetch).
npx --no-install commitlint --edit "$MSG_FILE"

LEN=$(printf '%s' "$MSG_HEAD" | wc -c)
if [ "$LEN" -gt 72 ]; then
	echo "[commit-msg] ⚠ subject is ${LEN} chars (>72). GitHub will truncate it — consider shortening." >&2
fi

exit 0
